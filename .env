# Supabase Configuration
# Replace these with your actual Supabase project credentials to enable the live database.
# If left blank, the app will automatically fall back to localStorage engine mode.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Lemon Squeezy SaaS Configuration
# Replace with your actual Lemon Squeezy checkout buy URL (e.g. from your Lemon Squeezy Dashboard)
# For local testing, a standard demo URL can be set or left default.
VITE_LEMON_SQUEEZY_CHECKOUT_URL=https://yourstore.lemonsqueezy.com/checkout/buy/your-product-variant-id?embed=1
VITE_LEMON_SQUEEZY_PORTAL_URL=https://yourstore.lemonsqueezy.com/billing


